# ─── AI: OpenRouter ───────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
# Required for live AI diagnosis.
OPENROUTER_API_KEY=

# Any vision-capable model available on OpenRouter:
#   google/gemini-2.5-flash  ← fast & cheap (default)
#   anthropic/claude-opus-4-8
#   openai/gpt-4o
OPENROUTER_MODEL=google/gemini-2.5-flash

# ─── Weather: OpenWeatherMap ──────────────────────────────────────────────────
# Free tier at: https://openweathermap.org/api  (1 000 calls/day)
# Required for live weather.
OWM_API_KEY=

# Default field coordinates (centre of Chuy Valley, Kyrgyzstan)
FIELD_LAT=42.87
FIELD_LON=74.59

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000


# ─── Database: Supabase ───────────────────────────────────────────────────────
# Project URL from: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=

# Service-role secret from: Settings → API → Project API keys → service_role
# (NOT the anon/public key — service_role bypasses Row Level Security)
SUPABASE_SERVICE_ROLE_KEY=
