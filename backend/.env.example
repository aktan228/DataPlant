# ─── AI: OpenRouter ───────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
# Leave empty to run in SIMULATION mode (demo works without a key).
OPENROUTER_API_KEY=

# Any vision-capable model available on OpenRouter:
#   google/gemini-2.5-flash  ← fast & cheap (default)
#   anthropic/claude-opus-4-8
#   openai/gpt-4o
OPENROUTER_MODEL=google/gemini-2.5-flash

# ─── Weather: OpenWeatherMap ──────────────────────────────────────────────────
# Free tier at: https://openweathermap.org/api  (1 000 calls/day)
# Leave empty to use built-in mock weather data.
OWM_API_KEY=

# Default field coordinates (centre of Chuy Valley, Kyrgyzstan)
FIELD_LAT=42.87
FIELD_LON=74.59

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
